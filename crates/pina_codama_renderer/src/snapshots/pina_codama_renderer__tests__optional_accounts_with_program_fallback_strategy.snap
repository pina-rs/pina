pub const MAYBE_DISCRIMINATOR: u8 = 9u8;

/// Accounts.
#[derive(Clone, Debug)]
pub struct Maybe {
	pub optional_signer: Option<(solana_pubkey::Pubkey, bool)>,
}

impl Maybe {
	pub fn new() -> Self {
		Self {
			optional_signer: None,
		}
	}

	pub fn instruction(&self, data: MaybeInstructionData) -> solana_instruction::Instruction {
		self.instruction_with_remaining_accounts(data, &[])
	}

	#[allow(clippy::arithmetic_side_effects)]
	pub fn instruction_with_remaining_accounts(
		&self,
		data: MaybeInstructionData,
		remaining_accounts: &[solana_instruction::AccountMeta],
	) -> solana_instruction::Instruction {
		let mut accounts = Vec::with_capacity(1 + remaining_accounts.len());
		if let Some((optional_signer, signer)) = self.optional_signer {
			accounts.push(solana_instruction::AccountMeta::new_readonly(optional_signer, signer));
		}
		else {
			accounts.push(solana_instruction::AccountMeta::new_readonly(crate::OPTIONAL_PROGRAM_ID, false));
		}
		accounts.extend_from_slice(remaining_accounts);
		let data = bytemuck::bytes_of(&data).to_vec();

		solana_instruction::Instruction {
			program_id: crate::OPTIONAL_PROGRAM_ID,
			accounts,
			data,
		}
	}
}

#[repr(C)]
#[derive(Clone, Copy, Debug, PartialEq, Eq, bytemuck::Pod, bytemuck::Zeroable)]
pub struct MaybeInstructionData {
	pub discriminator: u8,
